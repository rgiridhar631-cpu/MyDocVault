{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true,
    "commonjs": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-constant-condition": "warn",
    "no-empty": "warn"
  },
  "ignorePatterns": ["node_modules/", "dist/", "demo_project/"]
}
