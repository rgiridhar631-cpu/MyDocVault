{
  "name": "mydocvault",
  "version": "1.0.0",
  "description": "Privacy-first AI document intelligence vault",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node -e \"require('./services/db').initDb().then(()=>console.log('DB ready'))\"",
    "lint": "eslint .",
    "format:check": "prettier --check \".\"",
    "format": "prettier --write \".\"",
    "type-check": "tsc -p jsconfig.json",
    "knip": "knip",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.0.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "knip": "^5.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}